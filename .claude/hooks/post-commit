#!/bin/sh
# Auto-snapshot: update project-state.md after each commit

CLAUDE_DIR="$(git rev-parse --show-toplevel)/.claude"
STATE_FILE="$CLAUDE_DIR/project-state.md"

[ -f "$STATE_FILE" ] || exit 0

LAST_MSG=$(git log -1 --pretty=%s)
LAST_DATE=$(date '+%Y-%m-%d %H:%M')
LAST_FILES=$(git diff-tree --no-commit-id -r --name-only HEAD | tr '\n' ' ')

SNAPSHOT="<!-- last-commit: [$LAST_DATE] $LAST_MSG -- $LAST_FILES-->"

# Use awk to replace or insert the snapshot comment (avoids sed delimiter conflicts)
if grep -q '^<!-- last-commit:' "$STATE_FILE"; then
  awk -v snap="$SNAPSHOT" '/^<!-- last-commit:/{print snap; next} {print}' "$STATE_FILE" > "${STATE_FILE}.tmp" \
    && mv "${STATE_FILE}.tmp" "$STATE_FILE"
else
  awk -v snap="$SNAPSHOT" 'NR==2{print snap} {print}' "$STATE_FILE" > "${STATE_FILE}.tmp" \
    && mv "${STATE_FILE}.tmp" "$STATE_FILE"
fi
